{
  "name": "flequit",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy cookie preferredLanguage baseLocale",
    "dev": "vite dev --host",
    "dev:e2e": "vite dev --port 10000 --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "lint": "eslint .",
    "lint:arch": "eslint src/lib",
    "format": "prettier --write .",
    "check": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:e2e": "npx playwright test",
    "test:prepare:automerge": "mkdir -p .tmp/tests/cargo/flequit-infrastructure-automerge/automerge .tmp/tests/cargo/flequit-infrastructure-automerge/json",
    "test:prepare:db": "cargo run --manifest-path src-tauri/Cargo.toml -p flequit-infrastructure-sqlite --bin migration_runner -- .tmp/tests/test_database.db",
    "test:prepare:db:force": "cargo run --manifest-path src-tauri/Cargo.toml -p flequit-infrastructure-sqlite --bin migration_runner -- .tmp/tests/test_database.db --force",
    "test:prepare": "bun run test:prepare:automerge && bun run test:prepare:db",
    "tauri": "export RUST_LOG=debug && tauri",
    "tauri:dev": "export RUST_LOG=debug && tauri dev --host",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@thisux/sveltednd": "^0.4.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-svelte": "^1.0.1",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@inlang/cli": "^3.1.11",
    "@inlang/paraglide-js": "2.18.0",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-sonner": "^1.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vaul-svelte": "^0.3.2",
    "vite": "^8.0.11",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.5"
  }
}
